#!/bin/bash

# ══════════════════════════════════════════════════════════════
#  TuTiVi Main Command
# ══════════════════════════════════════════════════════════════

source "$HOME/.config/tutivi/core/functions.sh"

COMMAND="$1"
shift

# ══════════════════════════════════════════════════════════════
#  HELP
# ══════════════════════════════════════════════════════════════

_show_help() {

    echo ""
    echo "   TuTiVi 0.1v By Intergames"
    echo ""
    echo "  Ejemplos de uso:"
    echo ""
    echo "    tutivi abrir <url>       Abre un video o lo agrega a la cola"
    echo "    tutivi agregar <url>     Agrega un video a la cola"
    echo "    tutivi pausa             Pausa / reanuda"
    echo "    tutivi siguiente         Siguiente video"
    echo "    tutivi detener           Cierra TuTiVi"
    echo "    tutivi actual            Muestra información actual"
    echo "    tutivi titulo            Muestra título en pantalla"
    echo "    tutivi estado            Estado del reproductor"
    echo ""
    echo ""    
    echo ""
}

# ══════════════════════════════════════════════════════════════
#  PLAY
# ══════════════════════════════════════════════════════════════

_tutivi_play() {

    local URL

    URL=$(_tutivi_parse_url "$1")

    [[ -z "$URL" ]] && \
        echo "[ERROR] URL inválida." && return 1

    if _tutivi_running; then
        _tutivi_add "$URL"
        return 0
    fi

    _tutivi_start_mpv "$URL"

    _tutivi_title_watch

    sleep 2

    VIDEO_TITLE=""

    for ((i=1; i<=15; i++)); do

        VIDEO_TITLE=$(
            _tutivi_cmd '{"command":["get_property","media-title"]}' | \
            python3 -c '
import sys, json
try:
    d = json.load(sys.stdin)
    title = d.get("data", "")
    print(title.strip() if isinstance(title, str) else "")
except Exception:
    print("")
'
        )

        # Debuug del titulo
        #echo "DEBUG VIDEO_TITLE=[$VIDEO_TITLE]"

        # Si YA es válido
        if [[ -n "$VIDEO_TITLE" \
           && "$VIDEO_TITLE" != "?" \
           && "$VIDEO_TITLE" != "title" \
           && "$VIDEO_TITLE" != *"watch?v="* \
           && "$VIDEO_TITLE" != http://* \
           && "$VIDEO_TITLE" != https://* ]]; then

        _tutivi_osd $'TuTiVi Player:\n'"$VIDEO_TITLE" 5000
            break
        fi

        sleep 1
    done

    # Si nunca encontró título válido
    if [[ -z "$VIDEO_TITLE" \
       || "$VIDEO_TITLE" == "?" \
       || "$VIDEO_TITLE" == "title" \
       || "$VIDEO_TITLE" == *"watch?v="* \
       || "$VIDEO_TITLE" == http://* \
       || "$VIDEO_TITLE" == https://* ]]; then

        _tutivi_osd "TuTiVi Player - Sin título" 5000
    fi
}

# ══════════════════════════════════════════════════════════════
#  ADD TO QUEUE
# ══════════════════════════════════════════════════════════════

_tutivi_add() {

    local URL

    URL=$(_tutivi_parse_url "$1")

    [[ -z "$URL" ]] && \
        echo "[ERROR] URL inválida." && return 1

    ! _tutivi_running && \
        echo "[ERROR] mpv no está corriendo." && return 1

    _tutivi_cmd \
        '{"command":["loadfile","'"$URL"'","append-play"]}' >/dev/null

    _tutivi_title_watch

    _tutivi_osd "✔ Nuevo Video Agregado a la cola..." 5000
}

# ══════════════════════════════════════════════════════════════
#  STOP
# ══════════════════════════════════════════════════════════════

_tutivi_stop() {

    local MPV_PID=""
    local WATCH_PID=""

    # Intentar obtener PID desde socket
    if _tutivi_socket_alive; then
        MPV_PID=$(
            _tutivi_cmd '{"command":["get_property","pid"]}' | \
            python3 -c '
import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get("data", ""))
except Exception:
    print("")
'
        )

        _tutivi_cmd '{"command":["quit"]}' >/dev/null 2>&1
        sleep 1
    fi

    rm -f "$MPV_SOCKET"

    if [[ -f "$TUTIVI_TITLE_WATCH_PID_FILE" ]]; then
        WATCH_PID="$(cat "$TUTIVI_TITLE_WATCH_PID_FILE" 2>/dev/null)"
        [[ -n "$WATCH_PID" ]] && kill "$WATCH_PID" 2>/dev/null
        rm -f "$TUTIVI_TITLE_WATCH_PID_FILE"
    fi


    # Si tenemos PID, forzar cierre si sigue vivo
    if [[ -n "$MPV_PID" ]] && kill -0 "$MPV_PID" 2>/dev/null; then
        kill "$MPV_PID" 2>/dev/null
        sleep 1
    fi

    if [[ -n "$MPV_PID" ]] && kill -0 "$MPV_PID" 2>/dev/null; then
        kill -9 "$MPV_PID" 2>/dev/null
    fi

    # Limpieza extra: solo procesos mpv con socket TuTiVi
    while read -r PID CMD; do
        [[ "$CMD" == *"input-ipc-server=$MPV_SOCKET"* ]] && kill "$PID" 2>/dev/null
    done < <(pgrep -a mpv)

    sleep 1

    while read -r PID CMD; do
        [[ "$CMD" == *"input-ipc-server=$MPV_SOCKET"* ]] && kill -9 "$PID" 2>/dev/null
    done < <(pgrep -a mpv)

    echo "TuTiVi detenido."
}

# ══════════════════════════════════════════════════════════════
#  PAUSE
# ══════════════════════════════════════════════════════════════

_tutivi_pause() {

    ! _tutivi_running && return 0

    _tutivi_cmd '{"command":["cycle","pause"]}' >/dev/null
}

# ══════════════════════════════════════════════════════════════
#  NEXT
# ══════════════════════════════════════════════════════════════

_tutivi_next() {

    ! _tutivi_running && return 0

    _tutivi_cmd '{"command":["playlist-next"]}' >/dev/null

    sleep 7

    _tutivi_title_osd
}

# ══════════════════════════════════════════════════════════════
#  CURRENT
# ══════════════════════════════════════════════════════════════

_tutivi_current() {

    ! _tutivi_running && \
        echo "Sin reproducción." && return 1

    _tutivi_cmd '{"command":["get_property","media-title"]}' | \
        python3 -c '
import sys, json
try:
    d = json.load(sys.stdin)
    title = d.get("data", "")
    print(title if title else "Sin título")
except Exception:
    print("Sin título")
'
}
# ══════════════════════════════════════════════════════════════
#  MAIN SWITCH
# ══════════════════════════════════════════════════════════════

case "$COMMAND" in

    play|abrir|reproducir)
        _tutivi_play "$1"
        ;;

    add|agregar)
        _tutivi_add "$1"
        ;;

    running|estado)
        if _tutivi_running; then
            echo "running"
            exit 0
        else
            echo "stopped"
            exit 1
        fi
        ;;

    stop|detener)
        _tutivi_stop
        ;;

    pause|pausa)
        _tutivi_pause
        ;;

    next|siguiente)
        _tutivi_next
        ;;

    current|actual)
        _tutivi_current
        ;;

    titulo|title)
        _tutivi_title_osd
        ;;

    *)
        _show_help
        ;;
esac