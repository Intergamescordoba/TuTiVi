#!/bin/bash

# ══════════════════════════════════════════════════════════════
#  TuTiVi Enlazador
#  Recibe URL por argumento o desde el portapapeles
# ══════════════════════════════════════════════════════════════

export HOME="${HOME:-/home/$USER}"
export DISPLAY="${DISPLAY:-:0}"

URL="$1"

if [[ -z "$URL" ]]; then
    URL=$(xclip -selection clipboard -o 2>/dev/null)
fi

URL="$(echo "$URL" | xargs)"

if [[ -z "$URL" ]]; then
    tutivi titulo
    exit 0
fi

if [[ "$URL" != http://* && "$URL" != https://* ]]; then
    tutivi titulo
    exit 0
fi

if tutivi estado >/dev/null 2>&1; then
    tutivi agregar "$URL"
else
    tutivi abrir "$URL"
fi